# Clerk (Track B - Frontend). Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional: Clerk URLs (defaults work for local dev)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# API (Track A - Backend). When Track A merges, set to use Next.js API routes
# NEXT_PUBLIC_USE_API=true
# NEXT_PUBLIC_API_BASE_URL=  (empty = same-origin /api/*)
